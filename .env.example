# Pimisa Voucher System - Environment Variables
# Copy this file to .env and fill in the values

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL="postgresql://pimisa:pimisa_secret@localhost:5432/pimisa_vouchers?schema=public"

# ─── JWT Authentication ─────────────────────────────────────────
JWT_SECRET="change-this-to-a-very-long-random-string-in-production-min-32-chars"
JWT_EXPIRES_IN="24h"

# ─── Email Configuration (SMTP) ─────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_NAME="Pimisa Voucher System"
SMTP_FROM_EMAIL="noreply@pimisa.co.tz"

# Example for other providers:
# SMTP_HOST="smtp.office365.com" (Office 365)
# SMTP_HOST="smtp.sendgrid.net" (SendGrid)
# SMTP_HOST="smtp.mailgun.org" (Mailgun)

# ─── SMS Provider (Africa's Talking) ────────────────────────────
AT_API_KEY="your-africastalking-api-key"
AT_USERNAME="sandbox"
AT_SENDER_ID="PIMISA"

# ─── SMS Provider (Twilio - alternative) ────────────────────────
# TWILIO_ACCOUNT_SID="your-twilio-account-sid"
# TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# TWILIO_PHONE_NUMBER="+1234567890"

# ─── SMS Provider Selection ─────────────────────────────────────
SMS_PROVIDER="africastalking"

# ─── Application ────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Pimisa Voucher System"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Logging ────────────────────────────────────────────────────
LOG_LEVEL="info"
# Options: error, warn, info, debug

# ─── Cron Jobs ──────────────────────────────────────────────────
ENABLE_CRON="false"
# Set to "true" in production to enable scheduled tasks
# Tasks: voucher expiration, daily summaries, weekly reports, DB cleanup

# ─── WhatsApp (Meta Cloud API) ─────────────────────────────────
WHATSAPP_ENABLED="false"
WHATSAPP_API_VERSION="v19.0"
WHATSAPP_ACCESS_TOKEN="your-meta-whatsapp-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-whatsapp-phone-number-id"

# ─── Voucher Configuration ──────────────────────────────────────
VOUCHER_EXPIRY_DAYS=7
VOUCHER_CODE_LENGTH=6

# ─── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
VOUCHER_VERIFY_RATE_LIMIT=5
